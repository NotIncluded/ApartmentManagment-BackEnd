### ==========================================

### APARTMENT SYSTEM - AUTH & USER MANAGEMENT TESTS

### ==========================================

### Variables

@baseUrl = http://localhost:8081

@adminEmail = admin@test.com
@adminPassword = $2a$10$N9qo8uLOickgx2ZMRZoMyeIjZAgcflY0V3E/5t6dv3Vv4YFQy1z9e

@tenantEmail = [tenant@test.com](mailto:tenant@test.com)
@tenantPassword = TenantPassword123

@tenantEmail2 = [tenant2@test.com](mailto:tenant2@test.com)
@tenantPassword2 = TenantPassword456

### ==========================================

### TEST 1: HEALTH CHECK

### ==========================================

GET {{baseUrl}}/health
Accept: application/json

### ==========================================

### TEST 2: REGISTER TENANT

### ==========================================

# @name registerTenant

POST {{baseUrl}}/auth/register
Content-Type: application/json

{
"name": "John Tenant",
"phone": "0812345678",
"email": "{{tenantEmail}}",
"password": "{{tenantPassword}}",
"role": "TENANT"
}

### ==========================================

### TEST 3: REGISTER SECOND TENANT

### ==========================================

POST {{baseUrl}}/auth/register
Content-Type: application/json

{
"name": "Jane Tenant",
"phone": "0887654321",
"email": "{{tenantEmail2}}",
"password": "{{tenantPassword2}}",
"role": "TENANT"
}

### ==========================================

### TEST 4: REGISTER ADMIN - SHOULD FAIL

### ==========================================

POST {{baseUrl}}/auth/register
Content-Type: application/json

{
"name": "Admin User",
"phone": "0811111111",
"email": "{{adminEmail}}",
"password": "{{adminPassword}}",
"role": "ADMIN"
}

