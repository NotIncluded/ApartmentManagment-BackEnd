### TEST 5: LOGIN TENANT

### ==========================================

# @name loginTenant

POST {{baseUrl}}/auth/login
Content-Type: application/json

{
"email": "{{tenantEmail}}",
"password": "{{tenantPassword}}"
}

### ==========================================

### TEST 6: LOGIN ADMIN

### ==========================================

# @name loginAdmin

POST {{baseUrl}}/auth/login
Content-Type: application/json

{
"email": "{{adminEmail}}",
"password": "{{adminPassword}}"
}

### ==========================================

### TEST 7: PROTECTED ROUTE - NO TOKEN

### ==========================================

POST {{baseUrl}}/user/create
Content-Type: application/json

{
"name": "Unauthorized User",
"phone": "0899999999",
"email": "[newuser@test.com](mailto:newuser@test.com)",
"password": "Password123",
"role": "TENANT"
}

### ==========================================

### TEST 8: TENANT TRY CREATE USER - SHOULD FAIL

### ==========================================

POST {{baseUrl}}/user/create
Content-Type: application/json
Authorization: Bearer {{loginTenant.response.body.data.access_token}}

{
"name": "Tenant Created User",
"phone": "0899999999",
"email": "[tenantcreate@test.com](mailto:tenantcreate@test.com)",
"password": "Password123",
"role": "TENANT"
}

### ==========================================

### TEST 9: ADMIN CREATE TENANT

### ==========================================

POST {{baseUrl}}/user/create
Content-Type: application/json
Authorization: Bearer {{loginAdmin.response.body.data.access_token}}

{
"name": "Created By Admin",
"phone": "0855555555",
"email": "[createdtenant@test.com](mailto:createdtenant@test.com)",
