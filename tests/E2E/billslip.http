### ==========================================
### APARTMENT SYSTEM - BILL SLIP TESTS
### ==========================================

### Variables
@baseUrl = http://localhost:8081
@staffEmail = staff@test.com
@staffPassword = staffpass
@tenantEmail = tenant@test.com
@tenantPassword = TenantPassword123

### ==========================================
### SETUP: LOGIN TENANT (To get token if you protect the route later)
### ==========================================
# @name loginTenant
POST {{baseUrl}}/auth/login
Content-Type: application/json

{
    "email": "{{tenantEmail}}",
    "password": "{{tenantPassword}}"
}

### ==========================================
### TEST 1: UPLOAD BILL SLIP - SUCCESS
### ==========================================
# Notice the boundary declaration in the Content-Type header
# Make sure test-slip.jpg exists in the same folder as this .http file!

POST {{baseUrl}}/billslips/upload
Authorization: Bearer {{loginTenant.response.body.data.access_token}} 
Content-Type: multipart/form-data; boundary=MyBoundaryForTesting

--MyBoundaryForTesting
Content-Disposition: form-data; name="bill_id"

BILL-001
--MyBoundaryForTesting
Content-Disposition: form-data; name="room_id"

ROOM-101
--MyBoundaryForTesting
Content-Disposition: form-data; name="slip"; filename="test-slip.jpg"
Content-Type: image/jpeg

< ./test-slip.jpg
--MyBoundaryForTesting--

### ==========================================
### TEST 2: UPLOAD BILL SLIP - MISSING FILE (SHOULD FAIL)
### ==========================================

POST {{baseUrl}}/billslips/upload
Content-Type: multipart/form-data; boundary=MyBoundaryForTesting

--MyBoundaryForTesting
Content-Disposition: form-data; name="bill_id"

BILL-002
--MyBoundaryForTesting
Content-Disposition: form-data; name="room_id"

ROOM-102
--MyBoundaryForTesting--

### ==========================================
### TEST 3: UPLOAD BILL SLIP - MISSING ROOM & BILL ID
### ==========================================

POST {{baseUrl}}/billslips/upload
Content-Type: multipart/form-data; boundary=MyBoundaryForTesting

--MyBoundaryForTesting
Content-Disposition: form-data; name="slip"; filename="test-slip.jpg"
Content-Type: image/jpeg

< ./test-slip.jpg
--MyBoundaryForTesting--