@baseUrl = http://localhost:8081

##################################################
### 1️⃣ Missing password and role
##################################################
POST {{baseUrl}}/user/create
Content-Type: application/json

{
  "username": "punnawat"
}

###

##################################################
### 2️⃣ Missing role only
##################################################
POST {{baseUrl}}/user/create
Content-Type: application/json

{
  "username": "punnawat",
  "password": "123456"
}

###

##################################################
### 3️⃣ Empty string values
##################################################
POST {{baseUrl}}/user/create
Content-Type: application/json

{
  "username": "",
  "password": "",
  "role": ""
}

###

##################################################
### 4️⃣ Invalid role value
##################################################
POST {{baseUrl}}/user/create
Content-Type: application/json

{
  "username": "punnawat",
  "password": "123456",
  "role": "SUPERADMIN"
}

###

##################################################
### 6️⃣ Valid request (Control Case)
##################################################
POST {{baseUrl}}/user/create
Content-Type: application/json

{
  "username": "punnawat123",
  "password": "123456",
  "role": "ADMIN"
}