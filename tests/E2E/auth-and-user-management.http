### ==========================================

### APARTMENT SYSTEM - AUTH & USER MANAGEMENT TESTS

### ==========================================

### Variables

@baseUrl = http://localhost:8080

@staffEmail = staff@test.com
@staffPassword = staffpass

@tenantEmail = tenant@test.com
@tenantPassword = TenantPassword123

@tenantEmail2 = tenant2@test.com
@tenantPassword2 = TenantPassword456

### ==========================================

### TEST 1: HEALTH CHECK

### ==========================================

GET {{baseUrl}}/health
Accept: application/json

### ==========================================

### TEST 2: REGISTER TENANT

### ==========================================

# @name registerTenant

POST {{baseUrl}}/auth/register
Content-Type: application/json

{
"name": "John Tenant",
"phone": "0812345678",
"email": "{{tenantEmail}}",
"password": "{{tenantPassword}}",
"role": "TENANT"
}

### ==========================================

### TEST 3: REGISTER SECOND TENANT

### ==========================================

POST {{baseUrl}}/auth/register
Content-Type: application/json

{
"name": "Jane Tenant",
"phone": "0887654321",
"email": "{{tenantEmail2}}",
"password": "{{tenantPassword2}}",
"role": "TENANT"
}

### ==========================================

### TEST 4: REGISTER STAFF

### ==========================================

POST {{baseUrl}}/auth/register
Content-Type: application/json

{
"name": "Staff User",
"phone": "0811111111",
"email": "{{staffEmail}}",
"password": "{{staffPassword}}",
"role": "STAFF"
}

### ==========================================

### TEST 5: LOGIN TENANT

### ==========================================

# @name loginTenant

POST {{baseUrl}}/auth/login
Content-Type: application/json

{
"email": "{{tenantEmail}}",
"password": "{{tenantPassword}}"
}

### ==========================================

### TEST 6: LOGIN TENANT 2

### ==========================================

# @name loginTenant2

POST {{baseUrl}}/auth/login
Content-Type: application/json

{
"email": "{{tenantEmail2}}",
"password": "{{tenantPassword2}}"
}

### ==========================================

### TEST 7: LOGIN STAFF

### ==========================================

# @name loginStaff

POST {{baseUrl}}/auth/login
Content-Type: application/json

{
"email": "{{staffEmail}}",
"password": "{{staffPassword}}"
}

### ==========================================

### TEST 8: PROTECTED ROUTE - NO TOKEN

### ==========================================

POST {{baseUrl}}/users
Content-Type: application/json

{
"name": "Unauthorized User",
"phone": "0899999999",
"email": "newuser@test.com",
"password": "Password123",
"role": "TENANT"
}

### ==========================================

### TEST 9: TENANT TRY CREATE USER - SHOULD FAIL

### ==========================================

POST {{baseUrl}}/users
Content-Type: application/json
Authorization: Bearer {{loginTenant.response.body.data.access_token}}

{
"name": "Tenant Created User",
"phone": "0899999999",
"email": "tenantcreate@test.com",
"password": "Password123",
"role": "TENANT"
}

### ==========================================

### TEST 10: STAFF CREATE TENANT

### ==========================================

# @name createdTenantByStaff

POST {{baseUrl}}/users
Content-Type: application/json
Authorization: Bearer {{loginStaff.response.body.data.access_token}}

{
"name": "Created By Staff",
"phone": "0855555555",
"email": "createdtenant@test.com",
"password": "TenantPassword789",
"role": "TENANT"
}

### ==========================================

### TEST 11: INVALID LOGIN

### ==========================================

POST {{baseUrl}}/auth/login
Content-Type: application/json

{
"email": "{{tenantEmail}}",
"password": "WrongPassword"
}

